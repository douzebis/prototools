{
  // Visual Studio Code Workspace configuration for oss-prototools development.
  //
  // IMPORTANT: Rust and Python support
  // rust-analyzer picks up rust-toolchain.toml (generated by nix-shell at the
  // repo root) automatically — no extra configuration needed.
  //
  // Python paths point to reproto/src/ where the reproto package lives.
  //
  // Recommended workflow:
  //   1. Open a terminal in the oss-prototools directory.
  //   2. Enter the nix-shell: 'nix-shell'
  //   3. Launch VS Code from the nix-shell: 'code .code-workspace'
  //
  // This approach ensures VS Code has access to all dependencies from the Nix
  // development environment.

  "folders": [
    {
      "path": "." // Project root
    }
  ],
  "settings": {
    // Python environment integration
    // .env is preprovisioned by the nix-shell
    "python.envFile": "${workspaceFolder}/.env",

    // Python environment — reproto sources live under reproto/src/
    "python.analysis.extraPaths": [
      "${workspaceFolder}/reproto/src"
    ],
    "python.autoComplete.extraPaths": [
      "${workspaceFolder}/reproto/src"
    ],

    // Terminal integration — ensure Python sees reproto/src/ in PYTHONPATH
    "terminal.integrated.env.linux": {
      "PYTHONPATH": "${workspaceFolder}/reproto/src:${env:PYTHONPATH}"
    },
    "terminal.integrated.env.osx": {
      "PYTHONPATH": "${workspaceFolder}/reproto/src:${env:PYTHONPATH}"
    },

    // Python interpreter (uses nix-shell python if available)
    "python.defaultInterpreterPath": "${env:PYTHON_INTERPRETER}",

    // Enable type checking
    "python.analysis.typeCheckingMode": "basic",

    // Code formatting
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true
  }
}
